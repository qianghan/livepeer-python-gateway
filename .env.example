# Livepeer Gateway — Environment Variables
# Copy to .env and fill in your values.

# ---------------------------------------------------------------------------
# Orchestrator / Network
# ---------------------------------------------------------------------------

# Orchestrator URL(s), comma-separated. Leave empty to use discovery.
ORCHESTRATOR_URL=

# Remote signer URL. Leave empty for offchain (no-payment) mode.
SIGNER_URL=

# Base64-encoded JSON token containing signer/discovery URLs and auth headers.
# Overrides SIGNER_URL when set. See README for encoding instructions.
LIVEPEER_TOKEN=

# ---------------------------------------------------------------------------
# Daydream (managed billing/signing)
# ---------------------------------------------------------------------------

# Daydream signer URL. When set, overrides SIGNER_URL.
# Requires a valid LIVEPEER_TOKEN with Daydream credentials.
DAYDREAM_URL=https://daydream.live

# ---------------------------------------------------------------------------
# Job Defaults
# ---------------------------------------------------------------------------

# Default AI model ID when not specified in the request.
DEFAULT_MODEL_ID=noop

# Frames per second for the media publisher.
FPS=24

# JPEG quality for output frames sent to browser (0-100).
JPEG_QUALITY=80

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Comma-separated list of valid API keys. Leave empty to disable auth (dev mode).
API_KEYS=

# Maximum concurrent jobs allowed per API key.
MAX_JOBS_PER_KEY=10

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Host and port for the web server.
HOST=0.0.0.0
PORT=8000
